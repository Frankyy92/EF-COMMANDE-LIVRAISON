<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Livraisons du <%= date %> – Livreur</title>
  <link rel="stylesheet" href="/public/css/style.css" />
</head>
<body>
  <%- include('../partials/header') %>
  <div class="layout">
    <%- include('../partials/side_nav') %>
    <main class="main-content">
      <div class="container">
        <div class="panel">
      <h1>Recapitulatif des livraisons – <%= date %></h1>
      <div class="toolbar" style="margin-bottom:20px; display:flex; flex-wrap:wrap; align-items:center; gap:10px;">
        <form method="get" action="/livreur" style="display:flex; gap:8px; align-items:center;">
          <input type="date" name="date" value="<%= date %>" />
          <button class="btn" type="submit">Afficher</button>
        </form>
        <!-- Lien pour télécharger le PDF de cette date -->
        <a class="btn secondary" href="/livreur/pdf/<%= date %>" target="_blank">Télécharger PDF</a>
      </div>
      <% if (recap.length === 0) { %>
        <p>Aucune commande verrouillée pour cette date.</p>
      <% } %>
      <% recap.forEach(order => { %>
        <div class="panel" style="margin-bottom:20px;">
          <h2><%= order.boutique_name %></h2>
          <p><strong>Statut :</strong> <%= order.delivered ? 'Livrée au livreur' : 'En attente' %></p>
          <table class="table">
            <thead>
              <tr><th>Produit</th><th style="text-align:right">Quantité</th></tr>
            </thead>
            <tbody>
              <% order.items.forEach(item => { %>
                <tr class="row"><td><%= item.name %></td><td style="text-align:right"><%= item.final_quantity %></td></tr>
              <% }) %>
            </tbody>
          </table>
          <% if (!order.delivered) { %>
            <form action="/livreur/deliver/<%= order.id %>" method="post" style="margin-top:10px;">
              <input type="hidden" name="date" value="<%= date %>" />
              <button class="btn ok" type="submit">Marquer livrée</button>
            </form>
          <% } %>
        </div>
      <% }) %>
        </div>
      </div>
    </main>
  </div>
</body>
</html>