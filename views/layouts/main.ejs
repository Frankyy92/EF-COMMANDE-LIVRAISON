<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof title !== 'undefined' ? title : 'Orderflow' %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="topbar">
    <div class="brand">Orderflow</div>
    <div class="role-badge"><%= typeof roleLabel !== 'undefined' ? roleLabel : '' %></div>
    <button class="burger" aria-label="Menu" data-burger>☰</button>
  </header>
  <div class="page">
    <% if(typeof showSidebar === 'undefined' || showSidebar) { %>
      <aside class="sidenav">
        <%- include('../partials/side_nav', {role: role}) %>
      </aside>
    <% } %>
    <main class="content">
      <%- body %>
    </main>
  </div>
  <script src="/js/mobile-nav.js"></script>
</body>
</html>
