<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Connexion - Orderflow</title>
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
  <div class="container" style="max-width:420px;margin:40px auto;">
    <h1>Connexion</h1>
    <% if (error) { %>
      <p class="error" style="color:#b00020"><%= error %></p>
    <% } %>
    <form action="/login" method="post">
      <div class="form-group">
        <label for="email">Email</label>
        <input style="width:100%" type="text" name="email" id="email" required value="admin@example.com">
      </div>
      <div class="form-group" style="margin-top:10px">
        <label for="password">Mot de passe</label>
        <input style="width:100%" type="password" name="password" id="password" required value="admin123">
      </div>
      <button type="submit" class="btn" style="margin-top:16px;width:100%">Se connecter</button>
    </form>
  </div>
</body>
</html>
