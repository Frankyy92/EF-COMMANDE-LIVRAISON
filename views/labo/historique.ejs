<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Historique des commandes – Labo</title>
  <link rel="stylesheet" href="/public/css/style.css" />
</head>
<body>
  <%- include('../partials/header') %>
  <div class="layout">
    <%- include('../partials/side_nav') %>
    <main class="main-content">
      <div class="container">
        <div class="panel">
      <h1>Historique des commandes</h1>
      <p>Cette page liste toutes les commandes enregistrées, triées par date (de la plus récente à la plus ancienne). Vous pouvez cliquer sur la date pour consulter le détail complet (voir page récapitulatif).</p>
      <table class="table">
        <thead>
          <tr>
            <th>Date de livraison</th>
            <th>Boutique</th>
            <th style="text-align:right">Total articles</th>
            <th>Statut</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% orders.forEach(order => { %>
            <% /* Déterminer le statut lisible et la classe associée */
               let statusLabel;
               let statusClass;
               if (!order.locked) {
                 statusLabel = 'Non traité';
                 statusClass = 'status-non-traite';
               } else if (order.locked && !order.delivered) {
                 statusLabel = 'En cours';
                 statusClass = 'status-en-cours';
               } else if (order.delivered && !order.received) {
                 statusLabel = 'Terminé';
                 statusClass = 'status-termine';
               } else if (order.received) {
                 statusLabel = 'Livré';
                 statusClass = 'status-livre';
               } else {
                 statusLabel = 'Indéfini';
                 statusClass = '';
               }
            %>
            <tr class="row">
              <td><%= order.delivery_date %></td>
              <td><%= order.boutique_name %></td>
              <td style="text-align:right"><%= order.totalItems %></td>
              <td><span class="status-badge <%= statusClass %>"><%= statusLabel %></span></td>
              <td><a class="btn ghost" href="/labo/recap/<%= order.delivery_date %>">Voir détail</a></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
        </div>
      </div>
    </main>
  </div>
</body>
</html>