<div class="card">
  <h2>Livreur — Tournée</h2>
  <form method="get">
    <label>Date</label>
    <input type="date" name="d" value="<%= date %>">
    <button class="btn" type="submit" style="margin-top:8px;">Filtrer</button>
  </form>
</div>
<% Object.keys(byShop).forEach(shopId => { const shop = shopsMap[shopId]; %>
  <div class="card">
    <h3><%= shop ? shop.name : shopId %></h3>
    <table>
      <thead><tr><th>Commande</th><th>Articles</th><th>Statut</th><th>Action</th></tr></thead>
      <tbody>
        <% byShop[shopId].forEach(o => { %>
          <tr>
            <td><%= o.id %></td>
            <td>
              <% o.items.forEach(it => { %>
                <div><%= productsMap[it.productId].name %> × <%= it.qty %></div>
              <% }) %>
            </td>
            <td><span class="status <%= o.status==='non-traite'?'pending':'done' %>"><%= o.status==='non-traite'?'Non traité':'Validé' %></span></td>
            <td>
              <% if(o.status==='non-traite'){ %>
                <form method="post" action="/livreur/valider">
                  <input type="hidden" name="id" value="<%= o.id %>">
                  <button class="btn success small">Marquer livré</button>
                </form>
              <% } else { %>
                <em>OK</em>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% }) %>
