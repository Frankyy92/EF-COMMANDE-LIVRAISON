<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Historique des commandes – Boutique</title>
  <link rel="stylesheet" href="/public/css/style.css" />
</head>
<body>
  <%- include('../partials/header') %>
  <div class="layout">
    <%- include('../partials/side_nav') %>
    <main class="main-content">
      <div class="container">
        <div class="panel">
          <h1>Historique de mes commandes</h1>
          <p>Retrouvez ici l'ensemble de vos commandes passées, classées par date. Vous pouvez accéder à la commande pour la modifier tant qu'elle n'est pas verrouillée, ou voir la réception une fois livrée.</p>
          <table class="table">
            <thead>
              <tr>
                <th>Date de livraison</th>
                <th style="text-align:right">Total articles</th>
                <th>Statut</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% orders.forEach(function(order) { %>
                <% /* Déterminer le statut lisible et la classe associée selon les indicateurs locked/delivered/received */
                   let statusLabel;
                   let statusClass;
                   if (!order.locked) {
                     statusLabel = 'Non traité';
                     statusClass = 'status-non-traite';
                   } else if (order.locked && !order.delivered) {
                     statusLabel = 'En cours';
                     statusClass = 'status-en-cours';
                   } else if (order.delivered && !order.received) {
                     statusLabel = 'Terminé';
                     statusClass = 'status-termine';
                   } else if (order.received) {
                     statusLabel = 'Livré';
                     statusClass = 'status-livre';
                   } else {
                     statusLabel = 'Indéfini';
                     statusClass = '';
                   }
                %>
                <tr class="row">
                  <td><%= order.delivery_date %></td>
                  <td style="text-align:right"><%= order.totalItems %></td>
                  <td><span class="status-badge <%= statusClass %>"><%= statusLabel %></span></td>
                  <td>
                    <% if (!order.locked) { %>
                      <a class="btn ghost" href="/boutique/order/<%= order.delivery_date %>">Modifier</a>
                    <% } else { %>
                      <a class="btn ghost" href="/boutique/reception/<%= order.delivery_date %>">Détails</a>
                    <% } %>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</body>
</html>