<div class="card">
  <h2><%= shop.name %> — Ma commande — <%= date %></h2>
  <input class="input" placeholder="Rechercher un produit..." oninput="filterRows(this.value)">
  <div class="chips" id="catChips">
    <span class="chip active" data-cat="all">Tout</span>
    <% categories.forEach(c=>{ %><span class="chip" data-cat="<%= c.id %>"><%= c.name %></span><% }) %>
    <a class="chip" href="/admin/products" title="Gérer produits (admin)">Gérer produits</a>
  </div>
</div>
<div class="card">
  <table id="prodTable"><thead><tr><th>Produit</th><th style="width:160px;">Quantité</th></tr></thead><tbody>
    <% products.forEach(p=>{ %>
      <tr data-name="<%= p.name.toLowerCase() %>" data-cat="<%= p.categoryId %>">
        <td><%= p.name %></td>
        <td class="qty">
          <button type="button" class="btn small" onclick="step(this,-1)">-</button>
          <input type="number" min="0" name="qty_<%= p.id %>" value="0">
          <button type="button" class="btn small" onclick="step(this,1)">+</button>
        </td>
      </tr>
    <% }) %>
  </tbody></table>
  <div style="margin-top:12px"></div>
  <form method="post" action="/boutique/<%= shop.id %>/<%= date %>/order">
    <% products.forEach(p=>{ %><input type="hidden" name="qty_<%= p.id %>" id="hidden_<%= p.id %>" value="0"><% }) %>
    <button class="btn primary" type="submit">Enregistrer la commande</button>
  </form>
</div>
<div class="card">
  <h3>Commandes existantes pour cette date</h3>
  <table><thead><tr><th>ID</th><th>Articles</th><th>Statut</th><th>Créée</th></tr></thead><tbody>
    <% orders.forEach(o=>{ %>
      <tr><td><%= o.id %></td>
        <td><% o.items.forEach(it=>{ %><div><%= productsMap[it.productId].name %> × <%= it.qty %></div><% }) %></td>
        <td><span class="status <%= o.status==='non-traite'?'pending':'done' %>"><%= o.status==='non-traite'?'Non traité':'Validé' %></span></td>
        <td><%= new Date(o.createdAt).toLocaleString() %></td></tr>
    <% }) %>
  </tbody></table>
</div>
<script>
function filterRows(q){ q=(q||'').toLowerCase(); document.querySelectorAll('#prodTable tbody tr').forEach(tr=>{ const n=tr.getAttribute('data-name'); tr.style.display=(!q||n.includes(q))?'':'none'; }); }
document.querySelectorAll('#catChips .chip').forEach(chip=>{ chip.addEventListener('click',()=>{ document.querySelectorAll('#catChips .chip').forEach(c=>c.classList.remove('active')); chip.classList.add('active'); const cat=chip.getAttribute('data-cat'); document.querySelectorAll('#prodTable tbody tr').forEach(tr=>{ const c=tr.getAttribute('data-cat'); tr.style.display=(cat==='all'||c===cat)?'':'none'; }); }); });
function step(btn,delta){ const input=btn.parentElement.querySelector('input[type=number]'); const val=Math.max(0,(parseInt(input.value||'0',10)+delta)); input.value=val; const name=input.name; const hid=document.getElementById('hidden_'+name.replace('qty_','')); if(hid) hid.value=val; }
document.querySelectorAll('#prodTable input[type=number]').forEach(inp=>{ inp.addEventListener('input',()=>{ const hid=document.getElementById('hidden_'+inp.name.replace('qty_','')); if(hid) hid.value=inp.value||0; }); });
</script>
