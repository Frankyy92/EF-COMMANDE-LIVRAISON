<div class="card">
  <h2><%= shop.name %> — Ma commande — <%= date %></h2>
  <form method="post" action="/boutique/<%= shop.id %>/<%= date %>/order">
    <label>Recherche rapide</label>
    <input placeholder="Rechercher un produit..." oninput="filterRows(this.value)">
    <div style="margin-top:16px;"></div>
    <table id="prodTable">
      <thead><tr><th>Produit</th><th>Prix (€)</th><th>Quantité</th></tr></thead>
      <tbody>
        <% products.forEach(p => { %>
          <tr data-name="<%= p.name.toLowerCase() %>">
            <td><%= p.name %></td>
            <td><%= p.price.toFixed(2) %></td>
            <td><input type="number" min="0" name="qty_<%= p.id %>" value="0"></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <div style="margin-top:12px;"></div>
    <button class="btn primary" type="submit">Enregistrer la commande</button>
  </form>
</div>
<script>
  function filterRows(q){
    q = (q||'').toLowerCase();
    document.querySelectorAll('#prodTable tbody tr').forEach(tr=>{
      const n = tr.getAttribute('data-name');
      tr.style.display = (!q || n.includes(q)) ? '' : 'none';
    });
  }
</script>
<div class="card">
  <h3>Commandes existantes pour cette date</h3>
  <table>
    <thead><tr><th>ID</th><th>Articles</th><th>Statut</th><th>Créée</th></tr></thead>
    <tbody>
      <% orders.forEach(o => { %>
        <tr>
          <td><%= o.id %></td>
          <td>
            <% o.items.forEach(it => { %>
              <div><%= productsMap[it.productId].name %> × <%= it.qty %></div>
            <% }) %>
          </td>
          <td><span class="status <%= o.status==='non-traite'?'pending':'done' %>"><%= o.status==='non-traite'?'Non traité':'Validé' %></span></td>
          <td><%= new Date(o.createdAt).toLocaleString() %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
