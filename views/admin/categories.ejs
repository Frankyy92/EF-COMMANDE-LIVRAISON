<div class="card">
  <h2>Catégories</h2>
  <form method="post" action="/admin/categories/add" style="margin-bottom:12px;">
    <label>Nom</label>
    <input name="name" required>
    <button class="btn primary" style="margin-top:8px;">Ajouter</button>
  </form>
  <table>
    <thead><tr><th>Nom</th><th>ID</th><th>Actions</th></tr></thead>
    <tbody>
      <% categories.forEach(c => { %>
        <tr>
          <td><%= c.name %></td>
          <td><%= c.id %></td>
          <td>
            <form method="post" action="/admin/categories/delete" style="display:inline;">
              <input type="hidden" name="id" value="<%= c.id %>">
              <button class="btn small" type="submit">Supprimer</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
