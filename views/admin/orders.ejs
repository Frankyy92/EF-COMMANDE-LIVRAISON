<div class="card">
  <h2>Commandes</h2>
  <table>
    <thead><tr><th>ID</th><th>Client</th><th>Articles</th><th>Statut</th><th>Actions</th></tr></thead>
    <tbody>
      <% orders.forEach(o => { %>
        <tr>
          <td><%= o.id %></td>
          <td><%= o.client %></td>
          <td>
            <% o.items.forEach(it => { %>
              <div><%= productsMap[it.productId].name %> × <%= it.qty %></div>
            <% }) %>
          </td>
          <td>
            <% if(o.status === 'non-traite'){ %>
              <span class="status pending">Non traité</span>
            <% } else { %>
              <span class="status done">Validé</span>
            <% } %>
          </td>
          <td>
            <% if(o.status === 'non-traite'){ %>
              <form method="post" action="/admin/orders/valider" style="display:inline;">
                <input type="hidden" name="id" value="<%= o.id %>">
                <button class="btn success small" type="submit">Valider</button>
              </form>
            <% } %>
            <form method="post" action="/admin/orders/delete" style="display:inline;">
              <input type="hidden" name="id" value="<%= o.id %>">
              <button class="btn small" type="submit">Supprimer</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
