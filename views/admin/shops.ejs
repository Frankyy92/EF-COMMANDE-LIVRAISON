
<div class="card"><h2>Boutiques</h2>
<form method="post" action="/admin/shops/add" style="margin-bottom:12px"><label>Nom</label><input class="input" name="name" required><label>Identifiant (URL)</label><input class="input" name="id" required placeholder="ex: neuilly"><button class="btn primary" style="margin-top:8px">Ajouter</button></form>
<table><thead><tr><th>Nom</th><th>ID</th><th>Actions</th></tr></thead><tbody>
<% shops.forEach(s=>{ %><tr><td><%= s.name %></td><td><%= s.id %></td><td><form method="post" action="/admin/shops/delete" style="display:inline"><input type="hidden" name="id" value="<%= s.id %>"><button class="btn small">Supprimer</button></form></td></tr><% }) %>
</tbody></table></div>
