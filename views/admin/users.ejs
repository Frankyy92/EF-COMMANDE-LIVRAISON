<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Utilisateurs - Admin - Orderflow</title>
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
  <%- include('../partials/header') %>
  <div class="layout">
    <%- include('../partials/side_nav') %>
    <main class="main-content">
      <div class="container">
    <h1>Utilisateurs</h1>
    <a href="/admin/users/new" class="button">Nouvel utilisateur</a>
    <table>
      <thead>
        <tr>
          <th>Email</th>
          <th>Rôle</th>
          <th>Boutique</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(function(u) { %>
          <tr>
            <td><%= u.email %></td>
            <td><%= u.role %></td>
            <td><%= u.boutique_name || '-' %></td>
            <td>
              <a href="/admin/users/<%= u.id %>/edit" class="button">Éditer</a>
              <form action="/admin/users/<%= u.id %>/delete" method="post" style="display:inline-block" onsubmit="return confirm('Supprimer cet utilisateur ?')">
                <button type="submit" class="button">Supprimer</button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
      </div>
    </main>
  </div>
</body>
</html>