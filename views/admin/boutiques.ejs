<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Boutiques - Admin - Orderflow</title>
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
  <%- include('../partials/header') %>
  <div class="layout">
    <%- include('../partials/side_nav') %>
    <main class="main-content">
      <div class="container">
    <h1>Boutiques</h1>
    <a href="/admin/boutiques/new" class="button">Nouvelle boutique</a>
    <table>
      <thead>
        <tr>
          <th>Nom</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% boutiques.forEach(function(b) { %>
          <tr>
            <td><%= b.name %></td>
            <td>
              <a href="/admin/boutiques/<%= b.id %>/edit" class="button">Éditer</a>
              <form action="/admin/boutiques/<%= b.id %>/delete" method="post" style="display:inline-block" onsubmit="return confirm('Supprimer cette boutique ?')">
                <button type="submit" class="button">Supprimer</button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
      </div>
    </main>
  </div>
</body>
</html>