<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product ? 'Modifier le produit' : 'Nouveau produit' %> - Orderflow</title>
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
  <%- include('../partials/header') %>
  <div class="layout">
    <%- include('../partials/side_nav') %>
    <main class="main-content">
      <div class="container">
    <h1><%= product ? 'Modifier le produit' : 'Nouveau produit' %></h1>
    <% if (error) { %>
      <p class="error"><%= error %></p>
    <% } %>
    <form action="<%= product ? '/admin/products/' + product.id + '/edit' : '/admin/products/new' %>" method="post">
      <div class="form-group">
        <label for="name">Nom</label>
        <input type="text" name="name" id="name" value="<%= product ? product.name : '' %>" required>
      </div>
      <div class="form-group">
        <label for="category_id">Catégorie</label>
        <select name="category_id" id="category_id" required>
          <option value="">--Choisir--</option>
          <% categories.forEach(function(cat) { %>
            <option value="<%= cat.id %>" <%= product && product.category_id == cat.id ? 'selected' : '' %>><%= cat.name %></option>
          <% }); %>
        </select>
      </div>
      <div class="form-group">
        <label>
          <input type="checkbox" name="is_crude" value="1" <%= product && product.is_crude ? 'checked' : '' %> >
          Produit livré cru ?
        </label>
      </div>
      <button type="submit" class="button"><%= product ? 'Mettre à jour' : 'Créer' %></button>
      </form>
      </div>
    </main>
  </div>
</body>
</html>