<div class="card">
  <h2>Livraisons</h2>
  <p>Vue simplifiée des commandes à livrer.</p>
  <table>
    <thead><tr><th>ID</th><th>Client</th><th>Articles</th><th>Statut</th><th>Actions</th></tr></thead>
    <tbody>
    <% orders.forEach(o => { %>
      <tr>
        <td><%= o.id %></td>
        <td><%= o.client %></td>
        <td>
          <% o.items.forEach(it => { %>
            <div><%= productsMap[it.productId].name %> × <%= it.qty %></div>
          <% }) %>
        </td>
        <td>
          <% if(o.status === 'non-traite'){ %>
            <span class="status pending">Non traité</span>
          <% } else { %>
            <span class="status done">Validé</span>
          <% } %>
        </td>
        <td>
          <% if(o.status === 'non-traite'){ %>
            <form method="post" action="/livreur/valider">
              <input type="hidden" name="id" value="<%= o.id %>">
              <button class="btn success small" type="submit">Marquer livré</button>
            </form>
          <% } else { %>
            <em>Aucune action</em>
          <% } %>
        </td>
      </tr>
    <% }) %>
    </tbody>
  </table>
</div>
